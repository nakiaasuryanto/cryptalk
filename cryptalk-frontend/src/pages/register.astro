  <main style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem;">
    <h1 style="font-family: var(--font-mono, monospace); color: #39d353; margin-bottom: 2rem;">Register</h1>
    <RegisterForm client:load />
  </main>
</MainLayout>