---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Cryptalk - Home">
  <main style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 2rem; text-align: center;">
    <div style="background: #DCCCAC; padding: 3rem; border-radius: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
      <h1 style="font-family: 'Nunito', sans-serif; color: #546B41; margin-bottom: 0.5rem; font-size: 2.5rem;">Cryptalk</h1>
      <p style="color: #6b6b6b; max-width: 400px; margin-bottom: 2rem; font-size: 1.1rem;">
        Chat aman dengan enkripsi AES-128. Pesanmu hanya bisa dibaca oleh yang punya kunci!
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center;">
        <a href="/login" style="padding: 0.875rem 2rem; background: #546B41; color: #fff; border-radius: 12px; font-weight: 700; text-decoration: none; transition: transform 0.2s;">Login</a>
        <a href="/register" style="padding: 0.875rem 2rem; background: #99AD7A; color: #fff; border-radius: 12px; font-weight: 700; text-decoration: none; transition: transform 0.2s;">Register</a>
      </div>
    </div>
  </main>
</MainLayout>
