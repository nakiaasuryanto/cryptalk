---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'AES Messenger' } = Astro.props;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AES-128 Encrypted Messenger for Kriptografi Makalah" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>