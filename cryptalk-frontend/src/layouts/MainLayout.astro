---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Cryptalk' } = Astro.props;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Cryptalk - Encrypted Messenger dengan AES-128" />
    <link rel="icon" type="image/png" href="/ICON_CT.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
