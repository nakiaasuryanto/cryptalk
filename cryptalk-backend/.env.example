# Backend Environment Variables for Railway

# Flask secrets (generate random strings for production)
SECRET_KEY=your-secret-key-here-change-in-prod
JWT_SECRET_KEY=your-jwt-secret-here-change-in-prod

# Supabase PostgreSQL connection string
# Get this from Supabase Dashboard > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Port (Railway sets this automatically via $PORT)
PORT=5001

# Allowed frontend origins (comma-separated)
# Update with your Railway frontend URL
ALLOWED_ORIGINS=https://your-frontend.up.railway.app,http://localhost:4321
